      <TableDataSource Name="Table" Alias="EcheanceContrat" DataType="System.Int32" Enabled="true" SelectCommand="select e.empmat, e.emplib, e.empfonc, c.concod, c.condat, c.empemb, c.empsort, s.soclib from employe e,contrat c,societe s&#13;&#10;where e.empcod = c.empcod and c.soccod = e.soccod and s.soccod = e.soccod&#13;&#10;and s.soccod = @soccod&#13;&#10;and c.empsort&gt;=@datedebut and c.empsort&lt;=@datefin;">
