<Report ScriptLanguage="CSharp" ReportInfo.Created="07/11/2025 12:45:45" ReportInfo.Modified="07/11/2025 20:50:59" ReportInfo.CreatorVersion="2024.2.20.0">
  <Dictionary>
	  <PostgresDataConnection Name="Connection" ConnectionString="rijcmlqSfQ2H/Siq8AJ5BWRwV5dPevq4wghVtMaiZ3kouGEbFRYQ+IgrJOIHKJ4mjiZArG8RiymlGPkUQMqqgSmKxNuc1oGk42wcgt6j+HzJw7ay7EHC/n7cZ0x4Zwp5049ieHbrLyxBZr9U0Bf0C5l5WaxQH3PxHDeSBlYvUp2sq8QwpNdLx9zlYyzPB0+uIJfsj1Uay0HT5L+hSVXBvwyLHNjw8qr1hUbxeobP9dqbBVKdU+Ii+l+5K2zGzdn+U68TO86">
		  <TableDataSource Name="Table" Alias="SimulationConge" DataType="System.Int32" Enabled="true" SelectCommand="WITH EmpList AS (&#13;&#10;    SELECT LTRIM(RTRIM(value)) AS Empcod FROM STRING_SPLIT(@empcod, ',')&#13;&#10;)&#13;&#10;SELECT&#13;&#10;    YEAR(@datedebut) AS Annee,&#13;&#10;    e.Empmat,&#13;&#10;    e.Emplib,&#13;&#10;    e.Empreg,&#13;&#10;    e.Empemb,&#13;&#10;    SUM(ISNULL(cg.NbCongeRecu, 0)) AS Nbcongerecu,&#13;&#10;    MAX(ISNULL(s.SoldeInit, 0)) AS Soldeinit,&#13;&#10;    MAX(ISNULL(s.SoldeInit, 0)) - SUM(ISNULL(cg.NbCongeRecu, 0)) AS Droitrestant,&#13;&#10;    SUM(ISNULL(sc.NbAbsences, 0)) AS Nbabsences&#13;&#10;FROM employe e&#13;&#10;JOIN EmpList el ON UPPER(LTRIM(RTRIM(e.Empcod))) = UPPER(LTRIM(RTRIM(el.Empcod)))&#13;&#10;&#13;&#10;LEFT JOIN (&#13;&#10;    SELECT Empcod, Soccod, SUM(Connbjour) AS NbCongeRecu&#13;&#10;    FROM Conge&#13;&#10;    WHERE Condep &gt;= @datedebut AND Conret &lt;= @datefin&#13;&#10;    GROUP BY Soccod, Empcod&#13;&#10;) cg ON cg.Soccod = e.Soccod AND cg.Empcod = e.Empcod&#13;&#10;&#13;&#10;LEFT JOIN (&#13;&#10;    SELECT Empcod, Soccod, SUM(Connbjour) AS NbAbsences&#13;&#10;    FROM Sanction&#13;&#10;    WHERE Condep &gt;= @datedebut AND Conret &lt;= @datefin&#13;&#10;    GROUP BY Soccod, Empcod&#13;&#10;) sc ON sc.Soccod = e.Soccod AND sc.Empcod = e.Empcod&#13;&#10;&#13;&#10;LEFT JOIN (&#13;&#10;    SELECT Soccod, Sitconge AS SoldeInit&#13;&#10;    FROM Site&#13;&#10;) s ON s.Soccod = e.Soccod&#13;&#10;&#13;&#10;WHERE e.Soccod = @soccod&#13;&#10;GROUP BY e.Empmat, e.Emplib, e.Empreg, e.Empemb, e.Soccod;&#13;&#10;">
        <Column Name="Annee" DataType="System.Int32"/>
        <Column Name="Empmat" DataType="System.String"/>
        <Column Name="Emplib" DataType="System.String"/>
        <Column Name="Empreg" DataType="System.String"/>
        <Column Name="Empemb" DataType="System.DateTime"/>
        <Column Name="Nbcongerecu" DataType="System.Double"/>
        <Column Name="Soldeinit" DataType="System.Single"/>
        <Column Name="Droitrestant" DataType="System.Double"/>
        <Column Name="Nbabsences" DataType="System.Double"/>
        <CommandParameter Name="soccod" DataType="22" Expression="[soccod]"/>
        <CommandParameter Name="empcod" DataType="22" Expression="[empcod]"/>
        <CommandParameter Name="datedebut" DataType="22" Expression="[datedebut]"/>
        <CommandParameter Name="datefin" DataType="22" Expression="[datefin]"/>
      </TableDataSource>
    </PostgresDataConnection>
  </Dictionary>
