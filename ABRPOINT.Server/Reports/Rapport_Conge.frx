<?xml version="1.0" encoding="utf-8"?>
<Report ScriptLanguage="CSharp">

	<Dictionary>

		<!-- PARAMETRE -->
		<Parameter Name="Concod" DataType="System.String"/>

		<PostgresDataConnection Name="Connection" ConnectionString="YOUR_CONNECTION">

			<TableDataSource Name="Table" Enabled="true"
			  SelectCommand="
SELECT  
  e.emplib,
  e.empfonc,
  e.empadr,
  e.emptel,
  e.empmob,
  c.condat,
  c.concod,
  c.condep,
  c.conret,
  c.connbjour,
  s.soclib,
  s.socadr,
  a.abscng
FROM EMPLOYE e
JOIN Conge c ON c.empcod = e.empcod
JOIN Societe s ON s.soccod = c.soccod
JOIN absence a ON a.soccod = s.soccod AND a.abscod = c.abscod
WHERE c.concod = @Concod">

				<!-- COLUMNS -->
				<Column Name="emplib" DataType="System.String"/>
				<Column Name="empfonc" DataType="System.String"/>
				<Column Name="empadr" DataType="System.String"/>
				<Column Name="emptel" DataType="System.String"/>
				<Column Name="empmob" DataType="System.String"/>
				<Column Name="condat" DataType="System.DateTime"/>
				<Column Name="condep" DataType="System.DateTime"/>
				<Column Name="conret" DataType="System.DateTime"/>
				<Column Name="connbjour" DataType="System.Double"/>
				<Column Name="soclib" DataType="System.String"/>
				<Column Name="socadr" DataType="System.String"/>
				<Column Name="abscng" DataType="System.String"/>

				<!-- PARAM -->
				<CommandParameter Name="Concod" DataType="22" Expression="[Concod]" />

			</TableDataSource>

		</PostgresDataConnection>
	</Dictionary>

	<ReportPage Name="Page1">

		<!-- HEADER -->
		<PageHeaderBand Height="80">

			<TextObject Left="250" Top="10" Width="250"
			  Text="DEMANDE DE CONGE"
			  HorzAlign="Center"
			  Font="Arial, 14pt, style=Bold"/>

			<TextObject Left="10" Top="10"
			  Text="[UpperCase([Table.soclib])]"/>

			<TextObject Left="500" Top="10"
			  Text="[FormatDateTime([Table.condat], &quot;dd/MM/yyyy&quot;)]"/>

		</PageHeaderBand>

		<!-- DATA -->
		<DataBand Name="Data1" DataSource="Table" Height="600">

			<TextObject Left="10" Top="20" Text="Nom:"/>
			<TextObject Left="150" Top="20" Text="[Table.emplib]"/>

			<TextObject Left="10" Top="50" Text="Fonction:"/>
			<TextObject Left="150" Top="50" Text="[Table.empfonc]"/>

			<TextObject Left="10" Top="80" Text="Adresse:"/>
			<TextObject Left="150" Top="80" Text="[Table.empadr]"/>

			<TextObject Left="10" Top="110" Text="TÃ©lÃ©phone:"/>
			<TextObject Left="150" Top="110" Text="[Table.emptel]"/>

			<TextObject Left="10" Top="140" Text="Mobile:"/>
			<TextObject Left="150" Top="140" Text="[Table.empmob]"/>

			<!-- TEXTE -->
			<TextObject Left="10" Top="200" Width="700"
			  Text="Je demande un congÃ© de [Table.connbjour] jour(s) du [FormatDateTime([Table.condep], &quot;dd/MM/yyyy&quot;)] au [FormatDateTime([Table.conret], &quot;dd/MM/yyyy&quot;)]"/>

			<!-- TYPE -->
			<TextObject Left="500" Top="20" Text="CongÃ© annuel"/>
			<TextObject Left="500" Top="50" Text="Maladie"/>
			<TextObject Left="500" Top="80" Text="Sans solde"/>
			<TextObject Left="500" Top="110" Text="Exceptionnel"/>

			<!-- CHECK -->
			<TextObject Left="460" Top="20"
			  Text="[Table.abscng] == &quot;0&quot; ? &quot;X&quot; : &quot;&quot;"/>

			<TextObject Left="460" Top="50"
			  Text="[Table.abscng] == &quot;N&quot; ? &quot;X&quot; : &quot;&quot;"/>

			<TextObject Left="460" Top="80"
			  Text="[Table.abscng] == &quot;5&quot; ? &quot;X&quot; : &quot;&quot;"/>

			<TextObject Left="460" Top="110"
			  Text="[Table.abscng] != &quot;0&quot; &amp;&amp; [Table.abscng] != &quot;N&quot; &amp;&amp; [Table.abscng] != &quot;5&quot; ? &quot;X&quot; : &quot;&quot;"/>

			<TextObject Left="10" Top="350" Text="Signature EmployÃ©"/>

		</DataBand>

	</ReportPage>
</Report>