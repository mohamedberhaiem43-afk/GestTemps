      <TableDataSource Name="Table" Alias="AutorisationSortie" DataType="System.Int32" Enabled="true" SelectCommand="select s.soclib,s.socadr,e.empmat,e.emplib,e.empfonc,a.concod,a.conmotif,a.connbjour,a.condat,a.condep,a.conret,a.conref,sit.sitlib from societe s,employe e,autoriser a,site sit&#13;&#10;where a.empcod = e.empcod and sit.sitcod = e.sitcod and s.soccod = a.soccod and a.soccod = e.soccod and s.soccod =@soccod and a.concod = @concod">
        <Column Name="soclib" DataType="System.String"/>
        <Column Name="empmat" DataType="System.String"/>
        <Column Name="emplib" DataType="System.String"/>
        <Column Name="empfonc" DataType="System.String"/>
        <Column Name="concod" DataType="System.String"/>
        <Column Name="conmotif" DataType="System.String"/>
        <Column Name="connbjour" DataType="System.Single"/>
        <Column Name="condat" DataType="System.DateTime"/>
        <Column Name="condep" DataType="System.DateTime"/>
        <Column Name="conret" DataType="System.DateTime"/>
        <Column Name="conref" DataType="System.String"/>
        <Column Name="sitlib" DataType="System.String"/>
        <Column Name="socadr" DataType="System.String"/>
        <CommandParameter Name="soccod" DataType="22" Expression="[soccod]"/>
        <CommandParameter Name="concod" DataType="22" Expression="[concod]"/>
