    <DataBand Name="Data1" Top="100.9" Width="718.2" Height="670.95" DataSource="Table">
      <TextObject Name="Text1" Left="9.45" Top="75.6" Width="699.3" Height="236.25" Text="NOM ET PRENOM: [AutorisationSortie.emplib] POSTE: [AutorisationSortie.empfonc] MATRICULE:  [AutorisationSortie.empmat]&#13;&#10;&#13;&#10;&#13;&#10;J'ai l'honneur de venir par la présente vous prier de bien vouloir m'accorder une autorisation de sortie pour une durée de [AutorisationSortie.connbjour] heure(s).&#13;&#10;&#13;&#10;&#13;&#10;Heure de sortie: [FormatDateTime([AutorisationSortie.condep], &quot;HH:mm&quot;)]&#13;&#10;Heure de retour: [FormatDateTime([AutorisationSortie.conret],&quot;HH:mm&quot;)]&#13;&#10;CAUSE JUSTIFICATION (MOTIF): [AutorisationSortie.conmotif]&#13;&#10;REPRISE DE TRAVAIL LE: [FormatDateTime([AutorisationSortie.conret],&quot;dd/MM/yyyy&quot;)]" Font="Arial, 10pt"/>
      <TextObject Name="Text2" Left="9.45" Top="321.3" Width="179.55" Height="18.9" Text="Signature de l'employé" Font="Arial, 10pt, style=Bold, Underline"/>
      <TextObject Name="Text3" Left="9.45" Top="444.15" Width="378" Height="18.9" Text="Visa DRH après vérification du nombre d'autorisation prises" Font="Arial, 10pt, style=Underline"/>
      <TextObject Name="Text4" Left="481.95" Top="444.15" Width="198.45" Height="18.9" Text="Visa du chef Hiérarchique" Font="Arial, 10pt, style=Bold, Underline"/>
      <TextObject Name="Text5" Left="9.45" Top="548.1" Width="689.85" Height="66.15" Text="NB:1-L'autorisation de sortie ne doit en aucun cas dépasser 2 heures,faut de quoi elle sera imputée sur le droit congé annuel&#13;&#10;2-Les autorisations de sortie ne doivent pas dépasser le nombre 2 fois par mois" Font="Arial, 10pt, style=Underline"/>
      <TextObject Name="Text13" Left="9.45" Top="28.35" Width="217.35" Height="18.9" Text="SITE: [AutorisationSortie.sitlib]" VertAlign="Center" Font="Arial, 10pt"/>
      <TextObject Name="Text14" Left="481.95" Top="28.35" Width="113.4" Height="18.9" Text="Date: sfax le " HorzAlign="Center" VertAlign="Center" Font="Arial, 10pt"/>
      <TextObject Name="Text10" Left="567" Top="28.35" Width="151.2" Height="18.9" Text="Date [FormatDateTime([Date],&quot;dd/MM/yyy&quot;)]" HorzAlign="Center" VertAlign="Center" Font="Arial, 10pt, style=Bold"/>
