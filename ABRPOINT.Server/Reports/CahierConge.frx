<?xml version="1.0" encoding="utf-8"?>
<Report ScriptLanguage="CSharp" ReportInfo.Created="07/10/2025 13:32:51" ReportInfo.Modified="07/22/2025 22:25:50" ReportInfo.CreatorVersion="2024.2.20.0">
  <Dictionary>
    <MsSqlDataConnection Name="Connection" ConnectionString="rijcmlqM7gJFg/iaLrqMhRfGy5lGs6DPzoJjdyNiQWYUwMeqzw319CJ4OWcvBmPrM/DeITLwRznFHHEa7EyTwLv1sbcgcjOmn3YXIhjcLd5t6rO3d3v+U6XpMlyHXrOXGk8vOrcMgSuBFLp4zERKW7kJyGW+/Au4iZSehAhnajiaYjiSX381bp3OgVV5LEWKxxz4BRgbNnhsCCyipzjrIW3Y9Ps9Q==">
      <TableDataSource Name="Table" Alias="CahierConge" DataType="System.Int32" Enabled="true" SelectCommand="WITH EmpList AS (&#13;&#10;    SELECT LTRIM(RTRIM(value)) AS Empcod &#13;&#10;    FROM STRING_SPLIT(@empcod, ',')&#13;&#10;),&#13;&#10;BaseData AS (&#13;&#10;    SELECT &#13;&#10;        e.Empcod,&#13;&#10;        e.Empmat,&#13;&#10;        e.Emplib,&#13;&#10;        e.Empdnais,&#13;&#10;        e.Empemb,&#13;&#10;        e.Empreg,&#13;&#10;        e.Empsbrut,&#13;&#10;        soc.soclib,&#13;&#10;        soc.socadr,&#13;&#10;        s.Sitconge AS Soldini,&#13;&#10;        cs.cal_trav,&#13;&#10;        cs.cal_nbh,&#13;&#10;        p.Parancemp AS AncienneteParam,&#13;&#10;        DATEDIFF(DAY, e.Empemb, @datedebut) / 365.0 AS EmpYears&#13;&#10;    FROM Employe e&#13;&#10;    JOIN EmpList el &#13;&#10;        ON UPPER(LTRIM(RTRIM(e.Empcod))) = UPPER(LTRIM(RTRIM(el.Empcod)))&#13;&#10;    LEFT JOIN Site s &#13;&#10;        ON s.Soccod = e.Soccod AND s.Sitcod = e.Sitcod&#13;&#10;    LEFT JOIN calendsoc cs &#13;&#10;        ON cs.Soccod = e.Soccod &#13;&#10;        AND cs.cal_an = CAST(YEAR(@datedebut) AS VARCHAR)&#13;&#10;        AND cs.cal_mois = RIGHT('00' + CAST(MONTH(@datedebut) AS VARCHAR), 2)&#13;&#10;        AND cs.Caltype = e.Caltype&#13;&#10;    LEFT JOIN Parametre p &#13;&#10;        ON p.Soccod = e.Soccod&#13;&#10;    LEFT JOIN Societe soc &#13;&#10;        ON soc.Soccod = e.Soccod&#13;&#10;    WHERE e.Soccod = @soccod&#13;&#10;),&#13;&#10;CongeData AS (&#13;&#10;    SELECT &#13;&#10;        c.Empcod,&#13;&#10;        c.Condep,&#13;&#10;        c.Conamdep,&#13;&#10;        c.Conret,&#13;&#10;        c.Conamret,&#13;&#10;        c.Connbjour&#13;&#10;    FROM Conge c&#13;&#10;    WHERE c.Soccod = @soccod&#13;&#10;      AND c.Condep &gt;= @datedebut&#13;&#10;      AND c.Conret &lt;= @datefin&#13;&#10;)&#13;&#10;&#13;&#10;SELECT &#13;&#10;    b.soclib,&#13;&#10;    b.socadr,&#13;&#10;    b.Empmat,&#13;&#10;    b.Emplib,&#13;&#10;    b.Empdnais,&#13;&#10;    b.Empemb,&#13;&#10;    b.Empreg,&#13;&#10;    b.Soldini,&#13;&#10;    b.cal_trav,&#13;&#10;    b.cal_nbh,&#13;&#10;    b.Empsbrut,&#13;&#10;    ISNULL(b.AncienneteParam, 5) AS AncienneteParam,&#13;&#10;&#13;&#10;    FLOOR(CASE &#13;&#10;        WHEN b.EmpYears &lt; ISNULL(b.AncienneteParam, 5) THEN 0 &#13;&#10;        ELSE b.EmpYears / ISNULL(b.AncienneteParam, 5) &#13;&#10;    END) AS Jouanc,&#13;&#10;&#13;&#10;    ROUND(CASE &#13;&#10;        WHEN b.cal_trav = 0 THEN 0 &#13;&#10;        ELSE b.Empsbrut / b.cal_trav &#13;&#10;    END, 4) AS Saljou,&#13;&#10;&#13;&#10;    ROUND(FLOOR(CASE &#13;&#10;        WHEN b.EmpYears &lt; ISNULL(b.AncienneteParam, 5) THEN 0 &#13;&#10;        ELSE b.EmpYears / ISNULL(b.AncienneteParam, 5) &#13;&#10;    END) * &#13;&#10;    CASE &#13;&#10;        WHEN b.cal_trav = 0 THEN 0 &#13;&#10;        ELSE b.Empsbrut / b.cal_trav &#13;&#10;    END, 4) AS Montanc,&#13;&#10;&#13;&#10;    cg.Condep AS Datdep,&#13;&#10;    cg.Conamdep AS Depam,&#13;&#10;    cg.Conret AS Datret,&#13;&#10;    cg.Conamret AS Retam,&#13;&#10;    cg.Connbjour AS Totdupres,&#13;&#10;&#13;&#10;    ROUND(cg.Connbjour * &#13;&#10;    CASE &#13;&#10;        WHEN b.cal_trav = 0 THEN 0 &#13;&#10;        ELSE b.Empsbrut / b.cal_trav &#13;&#10;    END, 4) AS Indemcong,&#13;&#10;&#13;&#10;    CASE &#13;&#10;        WHEN b.EmpYears &lt; ISNULL(b.AncienneteParam, 5) THEN cg.Connbjour &#13;&#10;        ELSE cg.Connbjour - FLOOR(b.EmpYears / ISNULL(b.AncienneteParam, 5)) &#13;&#10;    END AS Congedu,&#13;&#10;&#13;&#10;    ROUND(CASE &#13;&#10;        WHEN b.EmpYears &lt; ISNULL(b.AncienneteParam, 5) THEN &#13;&#10;            cg.Connbjour * CASE WHEN b.cal_trav = 0 THEN 0 ELSE b.Empsbrut / b.cal_trav END &#13;&#10;        ELSE &#13;&#10;            (cg.Connbjour - FLOOR(b.EmpYears / ISNULL(b.AncienneteParam, 5))) * &#13;&#10;            CASE WHEN b.cal_trav = 0 THEN 0 ELSE b.Empsbrut / b.cal_trav END &#13;&#10;    END, 4) AS Indemdu&#13;&#10;&#13;&#10;FROM BaseData b&#13;&#10;LEFT JOIN CongeData cg ON cg.Empcod = b.Empcod&#13;&#10;ORDER BY b.Empcod, cg.Condep DESC;">
        <Column Name="emplib" DataType="System.String"/>
        <Column Name="empdnais" DataType="System.String"/>
        <Column Name="empemb" DataType="System.DateTime"/>
        <Column Name="Empmat" DataType="System.String"/>
        <Column Name="Empreg" DataType="System.String"/>
        <Column Name="AncienneteParam" DataType="System.String"/>
        <Column Name="Empsbrut" DataType="System.Double"/>
        <Column Name="Soldini" DataType="System.Single"/>
        <Column Name="Indemcong" DataType="System.Double"/>
        <Column Name="cal_trav" DataType="System.Single"/>
        <Column Name="cal_nbh" DataType="System.Single"/>
        <Column Name="Jouanc" DataType="System.Decimal"/>
        <Column Name="Saljou" DataType="System.Double"/>
        <Column Name="Montanc" DataType="System.Double"/>
        <Column Name="Datdep" DataType="System.DateTime"/>
        <Column Name="Depam" DataType="System.String"/>
        <Column Name="Datret" DataType="System.DateTime"/>
        <Column Name="Retam" DataType="System.String"/>
        <Column Name="Totdupres" DataType="System.Single"/>
        <Column Name="Congedu" DataType="System.Single"/>
        <Column Name="Indemdu" DataType="System.Double"/>
        <Column Name="soclib" DataType="System.String"/>
        <Column Name="socadr" DataType="System.String"/>
        <CommandParameter Name="datedebut" DataType="4" Expression="[datedebut]"/>
        <CommandParameter Name="datefin" DataType="4" Expression="[datefin]"/>
        <CommandParameter Name="empcod" DataType="22" Expression="[empcod]"/>
        <CommandParameter Name="soccod" DataType="22" Expression="[soccod]"/>
      </TableDataSource>
    </MsSqlDataConnection>
  </Dictionary>
