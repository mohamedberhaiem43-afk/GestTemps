    <ReportTitleBand Name="ReportTitle1" Width="718.2" Height="1000">
      <TextObject Name="MainContent" Left="37.8" Top="37.8" Width="642.6" Height="900" Text="&lt;!--?xml version=&quot;1.0&quot; encoding=&quot;utf-8&quot;?--&gt;
&lt;report scriptlanguage=&quot;CSharp&quot; reportinfo.created=&quot;01/12/2026 17:03:25&quot; reportinfo.modified=&quot;01/29/2026 12:12:17&quot; reportinfo.creatorversion=&quot;2024.1.7.0&quot;&gt;
  &lt;dictionary&gt;
    &lt;mssqldataconnection name=&quot;Connection&quot; connectionstring=&quot;rijcmlqAFHGp6KQj27H4qUwAIR20hSnyrpNtgmeY+I5zyTmYE0HuZfX1hs9fAqnt4DRtzHm6rgmUW5jqSG1QnBcPDOxCmGAUt6xdCOa+Pz3gs9EUDo42l2k0kGVESqqjpXvJYc2Q4Q6jXj0ELzxBVLjkVF4dAGrVSVPPvanKoBM7W5S2JGEKfuaCeydvS0vtQ1o2wHRPPHFVTq/xz2LV8LJZ6MMTGRkvDD1+/g/PJfeRjVAlwChTjLqcZ7oXLpGt0y3p13F&quot;&gt;
      &lt;tabledatasource name=&quot;Table&quot; datatype=&quot;System.Int32&quot; enabled=&quot;true&quot; selectcommand=&quot;select e.empcod, e.emplib, e.empcin, e.empadr, e.empsbase, e.empemb, e.empsort,e.empdcin,
       sit.sitlib, dir.dirlib,
       s.soccod, s.soclib, s.socadr
from employe e
inner join societe s on e.soccod = s.soccod
left join site sit on e.sitcod = sit.sitcod and sit.soccod = e.soccod
left join direction dir on e.dircod = dir.dircod and dir.soccod = e.soccod
where e.empcod = @empcod 
  and s.soccod = @soccod&quot;&gt;
        &lt;column name=&quot;empcod&quot; datatype=&quot;System.String&quot;&gt;
        &lt;column name=&quot;emplib&quot; datatype=&quot;System.String&quot;&gt;
        &lt;column name=&quot;empcin&quot; datatype=&quot;System.String&quot;&gt;
        &lt;column name=&quot;empadr&quot; datatype=&quot;System.String&quot;&gt;
        &lt;column name=&quot;soccod&quot; datatype=&quot;System.String&quot;&gt;
        &lt;column name=&quot;soclib&quot; datatype=&quot;System.String&quot;&gt;
        &lt;column name=&quot;socadr&quot; datatype=&quot;System.String&quot;&gt;
        &lt;column name=&quot;empsbase&quot; datatype=&quot;System.Double&quot;&gt;
        &lt;column name=&quot;sitlib&quot; datatype=&quot;System.String&quot;&gt;
        &lt;column name=&quot;dirlib&quot; datatype=&quot;System.String&quot;&gt;
        &lt;column name=&quot;empemb&quot; datatype=&quot;System.DateTime&quot;&gt;
        &lt;column name=&quot;empsort&quot; datatype=&quot;System.DateTime&quot;&gt;
        &lt;column name=&quot;empdcin&quot; datatype=&quot;System.DateTime&quot;&gt;
        &lt;commandparameter name=&quot;empcod&quot; datatype=&quot;22&quot; expression=&quot;[empcod]&quot;&gt;
        &lt;commandparameter name=&quot;soccod&quot; datatype=&quot;22&quot; expression=&quot;[soccod]&quot;&gt;
      &lt;/commandparameter&gt;&lt;/commandparameter&gt;&lt;/column&gt;&lt;/column&gt;&lt;/column&gt;&lt;/column&gt;&lt;/column&gt;&lt;/column&gt;&lt;/column&gt;&lt;/column&gt;&lt;/column&gt;&lt;/column&gt;&lt;/column&gt;&lt;/column&gt;&lt;/column&gt;&lt;/tabledatasource&gt;
    &lt;/mssqldataconnection&gt;
