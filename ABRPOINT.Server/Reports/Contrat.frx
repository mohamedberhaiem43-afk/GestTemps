  &lt;reportpage name=&quot;Page1&quot; watermark.font=&quot;Arial, 60pt&quot;&gt;
    &lt;reporttitleband name=&quot;ReportTitle1&quot; width=&quot;718.2&quot; height=&quot;94.5&quot;&gt;
      &lt;shapeobject name=&quot;Shape1&quot; width=&quot;718.2&quot; height=&quot;94.5&quot;&gt;
      &lt;textobject name=&quot;Text2&quot; left=&quot;529.2&quot; top=&quot;9.45&quot; width=&quot;132.3&quot; height=&quot;18.9&quot; text=&quot;Le: [DateTime.Now.Day]/[DateTime.Now.Month]/[DateTime.Now.Year]&quot; horzalign=&quot;Center&quot; vertalign=&quot;Center&quot; font=&quot;Arial, 10pt&quot;&gt;
      &lt;textobject name=&quot;Text1&quot; left=&quot;217.35&quot; top=&quot;9.45&quot; width=&quot;302.4&quot; height=&quot;56.7&quot; text=&quot;CONTRAT DE TRAVAIL A DUREE DETERMINEE&quot; horzalign=&quot;Center&quot; vertalign=&quot;Center&quot; font=&quot;Arial, 10pt, style=Bold&quot;&gt;
      &lt;textobject name=&quot;Text30&quot; left=&quot;-9.45&quot; top=&quot;9.45&quot; width=&quot;226.8&quot; height=&quot;28.35&quot; text=&quot;[UpperCase([Table.soclib])]&quot; horzalign=&quot;Center&quot; font=&quot;Arial, 10pt, style=Bold&quot;&gt;
      &lt;textobject name=&quot;Text31&quot; left=&quot;-9.45&quot; top=&quot;47.25&quot; width=&quot;226.8&quot; height=&quot;47.25&quot; text=&quot;[UpperCase([Table.socadr])]&quot; horzalign=&quot;Center&quot; font=&quot;Arial, 10pt&quot;&gt;
      &lt;textobject name=&quot;Text3&quot; left=&quot;302.4&quot; top=&quot;66.15&quot; width=&quot;141.75&quot; height=&quot;18.9&quot; text=&quot;[Table.empcod]&quot; horzalign=&quot;Center&quot; vertalign=&quot;Center&quot; font=&quot;Arial, 10pt, style=Bold&quot;&gt;
      &lt;lineobject name=&quot;Line1&quot; left=&quot;226.8&quot; height=&quot;94.5&quot;&gt;
      &lt;lineobject name=&quot;Line2&quot; left=&quot;529.2&quot; height=&quot;94.5&quot;&gt;
    &lt;/lineobject&gt;&lt;/lineobject&gt;&lt;/textobject&gt;&lt;/textobject&gt;&lt;/textobject&gt;&lt;/textobject&gt;&lt;/textobject&gt;&lt;/shapeobject&gt;&lt;/reporttitleband&gt;
    &lt;pageheaderband name=&quot;PageHeader1&quot; top=&quot;97.7&quot; width=&quot;718.2&quot;&gt;
    &lt;databand name=&quot;Data1&quot; top=&quot;100.9&quot; width=&quot;718.2&quot; height=&quot;1294.65&quot; datasource=&quot;Table&quot;&gt;
      &lt;textobject name=&quot;Text4&quot; left=&quot;9.45&quot; top=&quot;9.45&quot; width=&quot;302.4&quot; height=&quot;18.9&quot; text=&quot;Le présent contrat de travail est conclu entre :&quot; vertalign=&quot;Center&quot; font=&quot;Arial, 10pt&quot;&gt;
      &lt;textobject name=&quot;Text5&quot; left=&quot;9.45&quot; top=&quot;47.25&quot; width=&quot;94.5&quot; height=&quot;18.9&quot; text=&quot;1- La Société&quot; vertalign=&quot;Center&quot; font=&quot;Arial, 10pt&quot;&gt;
      &lt;textobject name=&quot;Text6&quot; left=&quot;103.95&quot; top=&quot;47.25&quot; width=&quot;170.1&quot; height=&quot;18.9&quot; text=&quot;[Table.soclib]&quot; vertalign=&quot;Center&quot; font=&quot;Arial, 10pt, style=Bold&quot;&gt;
      &lt;textobject name=&quot;Text7&quot; left=&quot;302.4&quot; top=&quot;47.25&quot; width=&quot;66.15&quot; height=&quot;18.9&quot; text=&quot;sise&quot; vertalign=&quot;Center&quot; font=&quot;Arial, 10pt&quot;&gt;
      &lt;textobject name=&quot;Text8&quot; left=&quot;378&quot; top=&quot;47.25&quot; width=&quot;103.95&quot; height=&quot;18.9&quot; text=&quot;[Table.emplib]&quot; vertalign=&quot;Center&quot; font=&quot;Arial, 10pt, style=Bold&quot;&gt;
      &lt;textobject name=&quot;Text9&quot; left=&quot;510.3&quot; top=&quot;47.25&quot; width=&quot;179.55&quot; height=&quot;18.9&quot; text=&quot;d'une part
&quot; vertalign=&quot;Center&quot; font=&quot;Arial, 10pt&quot;&gt;
      &lt;textobject name=&quot;Text10&quot; left=&quot;9.45&quot; top=&quot;85.05&quot; width=&quot;151.2&quot; height=&quot;18.9&quot; text=&quot;2- Monsieur/Mme/Mlle&quot; vertalign=&quot;Center&quot; font=&quot;Arial, 10pt&quot;&gt;
      &lt;textobject name=&quot;Text11&quot; left=&quot;160.65&quot; top=&quot;85.05&quot; width=&quot;113.4&quot; height=&quot;18.9&quot; text=&quot;[Table.emplib]&quot; vertalign=&quot;Center&quot; font=&quot;Arial, 10pt, style=Bold&quot;&gt;
      &lt;textobject name=&quot;Text12&quot; left=&quot;283.5&quot; top=&quot;85.05&quot; width=&quot;434.7&quot; height=&quot;18.9&quot; text=&quot;; CIN n° : [Table.empcin] délivré le : [FormatDateTime([Table.empdcin],&amp;quot;dd/MM/yyyy&amp;quot;)] ayant élu domicile à : 
&quot; vertalign=&quot;Center&quot; font=&quot;Arial, 10pt&quot;&gt;
      &lt;textobject name=&quot;Text13&quot; left=&quot;311.85&quot; top=&quot;122.85&quot; width=&quot;94.5&quot; height=&quot;18.9&quot; text=&quot;d'autre part&quot; vertalign=&quot;Center&quot; font=&quot;Arial, 10pt, style=Bold&quot;&gt;
      &lt;textobject name=&quot;Text14&quot; left=&quot;9.45&quot; top=&quot;122.85&quot; width=&quot;292.95&quot; height=&quot;18.9&quot; text=&quot;[Table.socadr]&quot; vertalign=&quot;Center&quot; font=&quot;Arial, 10pt&quot;&gt;
      &lt;textobject name=&quot;Text15&quot; left=&quot;9.45&quot; top=&quot;179.55&quot; width=&quot;699.3&quot; height=&quot;37.8&quot; text=&quot;Pour l'exécution du présent contrat et de ses suites, les parties font élection de domicile à leurs adresses respectives sus-indiquées.



&quot; font=&quot;Arial, 10pt&quot;&gt;
      &lt;textobject name=&quot;Text16&quot; left=&quot;9.45&quot; top=&quot;1030.05&quot; width=&quot;661.5&quot; height=&quot;264.6&quot; text=&quot;Le présent contrat prendra fin sans préavis ni indemnité dans l’un des cas suivants :
- Expiration du délai du contrat
- Faute grave commise par l’employé et stipulée par le code de travail
- Non respect par l’employé de ses engagements et devoirs.








Directeur Ressources Humaines	                                               L’employé(e)

&quot; font=&quot;Arial, 10pt&quot;&gt;
      &lt;textobject name=&quot;Text17&quot; left=&quot;18.9&quot; top=&quot;982.8&quot; width=&quot;226.8&quot; height=&quot;18.9&quot; text=&quot;Artcile 7 : Fin du contrat&quot; font=&quot;Arial, 10pt, style=Bold, Underline&quot;&gt;
        &lt;highlight&gt;
          &lt;condition expression=&quot;Value == 0&quot; font=&quot;Arial, 10pt&quot;&gt;
        &lt;/condition&gt;&lt;/highlight&gt;
      &lt;/textobject&gt;
      &lt;textobject name=&quot;Text18&quot; left=&quot;9.45&quot; top=&quot;907.2&quot; width=&quot;614.25&quot; height=&quot;66.15&quot; text=&quot;Les deux parties ont convenu de se référer à la législation du travail en vigueur pour tous les points qui ne sont pas évoqués par le présent contrat.

&quot; font=&quot;Arial, 10pt&quot;&gt;
      &lt;textobject name=&quot;Text19&quot; left=&quot;9.45&quot; top=&quot;878.85&quot; width=&quot;217.35&quot; height=&quot;18.9&quot; text=&quot;Article 6 : Point Divers :&quot; font=&quot;Arial, 10pt, style=Bold, Underline&quot;&gt;
      &lt;textobject name=&quot;Text20&quot; left=&quot;9.45&quot; top=&quot;774.9&quot; width=&quot;699.3&quot; height=&quot;85.05&quot; text=&quot;Monsieur/Mme [Table.emplib]  recevra un salaire de base de [Table.empsbase]  DT/Mois.
Il bénéficit d'une part de la couverture sociale et des accidents de travail et d'autre part du tenu de travail selon les législations en vigueur.
&quot; font=&quot;Arial, 10pt&quot;&gt;
      &lt;textobject name=&quot;Text21&quot; left=&quot;9.45&quot; top=&quot;756&quot; width=&quot;217.35&quot; height=&quot;18.9&quot; text=&quot;Article 5 : Rémunération :
&quot; font=&quot;Arial, 10pt, style=Bold, Underline&quot;&gt;
      &lt;textobject name=&quot;Text22&quot; left=&quot;9.45&quot; top=&quot;661.5&quot; width=&quot;699.3&quot; height=&quot;94.5&quot; text=&quot;Le contrat de  Monsieur/Mme [Table.emplib] est régi par les dispositions légales et conventionnelles applicables à l'entreprise, il est soumis au régime 48 h, Monsieur/Mme [Table.emplib] bénéficiera d’un jour de congé hebdomadaire désigné selon les nécessités de travail.&quot; font=&quot;Arial, 10pt&quot;&gt;
      &lt;textobject name=&quot;Text23&quot; left=&quot;9.45&quot; top=&quot;633.15&quot; width=&quot;217.35&quot; height=&quot;18.9&quot; text=&quot;Article 4 : Dispositions divers :
&quot; font=&quot;Arial, 10pt, style=Bold, Underline&quot;&gt;
      &lt;textobject name=&quot;Text24&quot; left=&quot;9.45&quot; top=&quot;548.1&quot; width=&quot;699.3&quot; height=&quot;75.6&quot; text=&quot;
Monsieur/Mme [Table.emplib]  s’engage à exercer ses fonctions à [Table.socadr]  ou dans tout autre lieu qui lui sera désigné par la Direction Général sans que ce changement ne lui ouvre droit à aucune réparation ou indemnisation de quelque nature qu’elle soit.
&quot; font=&quot;Arial, 10pt&quot;&gt;
      &lt;textobject name=&quot;Text25&quot; left=&quot;9.45&quot; top=&quot;529.2&quot; width=&quot;217.35&quot; height=&quot;18.9&quot; text=&quot;Article 3 : Lieu de travail :
&quot; font=&quot;Arial, 10pt, style=Bold, Underline&quot;&gt;
      &lt;textobject name=&quot;Text26&quot; left=&quot;18.9&quot; top=&quot;340.2&quot; width=&quot;689.85&quot; height=&quot;160.65&quot; text=&quot;Monsieur/Mme : [Table.emplib] s’engage à respecter :
-	Les horaires du travail
-	Le secret professionnel dont il/elle pourrait prendre connaissance à l’occasion de l’exercice de ses fonctions.
-	Ses collègues et ses supérieurs hiérarchiques.

     En outre, il/elle doit veiller au :
-	Bon fonctionnement du service ou du département auquel il/elle est affecté(e).
-	Au respect du règlement intérieur de la société qui constitue une partie intégrante du contrat et dont il reconnaît avoir pris connaissance lors de son embauche.&quot; font=&quot;Arial, 10pt&quot;&gt;
      &lt;textobject name=&quot;Text27&quot; left=&quot;9.45&quot; top=&quot;311.85&quot; width=&quot;292.95&quot; height=&quot;18.9&quot; text=&quot;Article 2 : Obligations Professionnelles :&quot; font=&quot;Arial, 10pt, style=Bold, Underline&quot;&gt;
      &lt;textobject name=&quot;Text28&quot; left=&quot;9.45&quot; top=&quot;264.6&quot; width=&quot;699.3&quot; height=&quot;47.25&quot; text=&quot;La société sus indiquée accepte d’engager Monsieur : [Table.emplib] en qualité : DIRECTEUR D'[Table.dirlib]
pour une durée allant du [FormatDateTime([Table.empemb],&amp;quot;dd/MM/yyyy&amp;quot;)] au [FormatDateTime([Table.empsort],&amp;quot;dd/MM/yyyy&amp;quot;)]

&quot; font=&quot;Arial, 10pt&quot;&gt;
      &lt;textobject name=&quot;Text29&quot; left=&quot;9.45&quot; top=&quot;236.25&quot; width=&quot;292.95&quot; height=&quot;18.9&quot; text=&quot;Article 1 : Duréé du contrat&quot; font=&quot;Arial, 10pt, style=Bold, Underline&quot;&gt;
    &lt;/textobject&gt;&lt;/textobject&gt;&lt;/textobject&gt;&lt;/textobject&gt;&lt;/textobject&gt;&lt;/textobject&gt;&lt;/textobject&gt;&lt;/textobject&gt;&lt;/textobject&gt;&lt;/textobject&gt;&lt;/textobject&gt;&lt;/textobject&gt;&lt;/textobject&gt;&lt;/textobject&gt;&lt;/textobject&gt;&lt;/textobject&gt;&lt;/textobject&gt;&lt;/textobject&gt;&lt;/textobject&gt;&lt;/textobject&gt;&lt;/textobject&gt;&lt;/textobject&gt;&lt;/textobject&gt;&lt;/textobject&gt;&lt;/textobject&gt;&lt;/databand&gt;
    &lt;pagefooterband name=&quot;PageFooter1&quot; top=&quot;1398.75&quot; width=&quot;718.2&quot; height=&quot;18.9&quot;&gt;
  &lt;/pagefooterband&gt;&lt;/pageheaderband&gt;&lt;/reportpage&gt;
&lt;/report&gt;
" HtmlTags="true" Font="Arial, 10pt"/>
