# =============================================================================
# Secrets de sauvegarde — Concorde Workforce
#
# Copier vers /etc/abrpoint/backup.env sur l'hôte Docker (chmod 600, root:root)
# puis renseigner les valeurs. Ce fichier est lu par les timers systemd (ou le
# job cron) installés par scripts/setup-backup-cron.sh, qui l'injectent comme
# environnement de scripts/backup.sh et scripts/restore-test.sh.
#
#   sudo install -m 600 -o root -g root .env.backup.example /etc/abrpoint/backup.env
#   sudo nano /etc/abrpoint/backup.env      # renseigner les secrets
#   sudo bash scripts/setup-backup-cron.sh  # (ré)installer la planification
# =============================================================================

# ── Alerte en cas d'échec ───────────────────────────────────────────────────
# Adresse destinataire de l'email envoyé si une sauvegarde ou un test de
# restauration échoue (déclenché par OnFailure= systemd / wrapper cron).
# Nécessite un mailer fonctionnel sur l'hôte (bsd-mailx + relais SMTP).
ALERT_EMAIL=mohamed@concorde-work-force.com

# ── Postgres ────────────────────────────────────────────────────────────────
# DOIT correspondre au POSTGRES_PASSWORD du docker-compose de la base.
POSTGRES_PASSWORD=CHANGE_ME_min32chars_random
POSTGRES_USER=abrpoint

# Noms des conteneurs (défauts du docker-compose).
DB_CONTAINER=abrpoint.database
SERVER_CONTAINER=abrpoint.server

# Dossier de sortie local des dumps (défaut: /var/backups/abrpoint).
BACKUP_DIR=/var/backups/abrpoint

# ── Chiffrement + hors-site (RGPD Art. 32) ──────────────────────────────────
# Clé symétrique 32+ caractères :  openssl rand -base64 48
# REQUISE pour l'upload S3. Si vide → dumps locaux EN CLAIR uniquement (dev).
# ⚠ À conserver hors du serveur (gestionnaire de secrets) : sans elle, les
#   backups chiffrés sur S3 sont irrécupérables.
BACKUP_ENC_KEY=

# Bucket S3 en région UE (versioning + Object Lock activés côté infra).
# Si vide → upload distant désactivé (mode purement local).
S3_BUCKET=
S3_PREFIX=prod/
AWS_DEFAULT_REGION=eu-west-3

# Credentials AWS — ou préférer un rôle IAM / instance profile (laisser vide).
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
