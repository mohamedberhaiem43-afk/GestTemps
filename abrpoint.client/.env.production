# For production builds (gets overridden by Docker)
VITE_REACT_APP_API_URL=/api

# URL « vanity » encodée dans le QR code de la page /download. Décommenter et
# pointer sur le domaine raccourci UNE FOIS la redirection OVH active (sinon
# scanner le QR donne "site indisponible"). Tant que cette ligne est commentée,
# la page utilise window.location.origin/download — c.-à-d. l'URL qui sert
# effectivement la page, garantie de fonctionner.
#
# VITE_DOWNLOAD_VANITY_URL=https://concordeworkly.com