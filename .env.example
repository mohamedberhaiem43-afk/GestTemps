# Template du fichier .env à placer à côté de docker-compose.yml sur le serveur.
# Ne JAMAIS committer la version remplie — .env est .gitignored.
#
# En CI/CD (GitHub Actions), ce fichier est régénéré automatiquement à chaque
# déploiement à partir des secrets GitHub (cf. .github/workflows/main.yml).
# Sur un déploiement manuel : copier ce fichier en .env et remplir les valeurs.
#
#  Pour le dev local : utiliser `dotnet user-secrets` plutôt que .env (les valeurs
# restent hors du repo dans %APPDATA%\Microsoft\UserSecrets\).

# ─── PostgreSQL ──────────────────────────────────────────────────────────────
# Mot de passe du superuser PG. Utilisé par le conteneur abrpoint.database au
# premier démarrage (POSTGRES_PASSWORD) ET injecté dans les connection strings
# de l'app via ConnectionStrings__MasterConnection / __TenantTemplate.
# Min. 24 chars, mix alphanumérique. Si compromis : `docker compose down -v` +
# rotation + recréation (les données seront perdues — backup d'abord).
POSTGRES_PASSWORD=CHANGE_ME_TO_A_LONG_RANDOM_STRING

# ─── SMTP (OVH ssl0.ovh.net) ─────────────────────────────────────────────────
# Sans ces variables, les emails (réinit MDP, validations) échouent silencieusement.
# SMTP_FROM_EMAIL DOIT être identique à SMTP_USERNAME sur OVH (sinon 553 sender).
SMTP_HOST=ssl0.ovh.net
SMTP_PORT=587
SMTP_USERNAME=contact@example.com
SMTP_PASSWORD=mailbox_password_here
SMTP_FROM_EMAIL=contact@example.com
SMTP_FROM_NAME=Concorde Work Force

# ─── OpenRouter (DocumentScan + RAG + AI templates) ──────────────────────────
# Récupérer une clé sur https://openrouter.ai/keys (commence par sk-or-v1-...).
# Sans cette clé, les 3 features renvoient 500 avec un message actionnable.
OPENROUTER_API_KEY=sk-or-v1-REPLACE_WITH_REAL_KEY

# ─── Optionnels ──────────────────────────────────────────────────────────────
# Anthropic direct (si Rag__Anthropic__UseOpenRouter=false dans compose).
ANTHROPIC_API_KEY=

# Clé partagée pour authentifier les appels backend → sidecar RAG.
RAG_SIDECAR_KEY=

# URL de l'APK Android (artefact EAS Expo). Default codé dans compose si vide.
APK_URL=
