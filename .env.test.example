# Template à copier en .env.test SUR LE SERVEUR DE TEST.
#   cp .env.test.example .env.test
#   docker compose -f docker-compose.test.yml --env-file .env.test up -d
#
# NE JAMAIS commiter .env.test (ajouté à .gitignore).

# ─── PostgreSQL embarqué ────────────────────────────────────────────────────
# Superuser de la base de test embarquée. Pas de lien avec la prod : ce sont
# des credentials propres à la machine de test.
POSTGRES_USER=abrpoint
POSTGRES_PASSWORD=CHANGE_ME_test_db_password_min24chars

# ─── Bootstrap admin (créé au 1er démarrage si la base est vide) ────────────
ADMIN_EMAIL=admin@abrpoint.local
ADMIN_BOOTSTRAP_PASSWORD=CHANGE_ME_admin_password

# ─── Secrets applicatifs (obligatoires) ─────────────────────────────────────
# Génération :
#   openssl rand -base64 48      # JWT_SECRET
#   openssl rand -hex 32         # AES_KEY (32 hex = 16 octets)
JWT_SECRET=CHANGE_ME_jwt_secret_min32_chars
AES_KEY=CHANGE_ME_aes_key_16_24_or_32_chars

# ─── Domaine (laisser localhost pour un test par IP) ────────────────────────
ROOT_DOMAIN=localhost

# ─── RAG / IA (optionnel) ───────────────────────────────────────────────────
# Mettre RAG_ENABLED=false pour un test léger sans télécharger le modèle e5-large
# (~2,2 Go). Pensez alors à commenter rag-svc + qdrant dans docker-compose.test.yml.
RAG_ENABLED=true
RAG_SIDECAR_KEY=CHANGE_ME_random_shared_token
ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=
GEMINI_API_KEY=

# ─── SMTP (optionnel en test) ───────────────────────────────────────────────
SMTP_HOST=ssl0.ovh.net
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_NAME=Concorde Work Force (TEST)
SMTP_FROM_EMAIL=

# ─── Stripe (optionnel en test) ─────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
