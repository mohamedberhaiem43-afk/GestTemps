# Template à copier en .env.db SUR LE SERVEUR DB.
#   cp .env.db.example .env.db
#   docker compose -f docker-compose.db.yml --env-file .env.db up -d
#
# NE JAMAIS commiter .env.db.

# Superuser Postgres créé au premier démarrage. Doit garder CREATEDB (cas
# par défaut). Pour rotation : `ALTER USER abrpoint WITH PASSWORD '...'`
# puis mettre à jour POSTGRES_PASSWORD côté .env.app et redémarrer le
# serveur applicatif.
POSTGRES_USER=abrpoint
POSTGRES_PASSWORD=CHANGE_ME_min32chars_random
