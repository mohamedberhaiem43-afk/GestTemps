# Template à copier en .env.app SUR LE SERVEUR APPLICATIF.
#   cp .env.app.example .env.app
#   docker compose -f docker-compose.app.yml --env-file .env.app up -d
#
# NE JAMAIS commiter .env.app.

# ─── Connexion Postgres distant ────────────────────────────────────────────
# IP/DNS du serveur DB. Préférer une IP WireGuard / VPC privé. Si IP
# publique : firewaller le port 5432 côté DB pour n'accepter QUE l'IP de
# ce serveur applicatif (cf. en-tête docker-compose.db.yml).
DB_HOST=10.0.0.2
DB_PORT=5432

# Doivent matcher exactement avec .env.db sur le serveur DB.
POSTGRES_USER=abrpoint
POSTGRES_PASSWORD=CHANGE_ME_min32chars_random

# ─── Bootstrap admin (créé au premier démarrage si la DB est vide) ─────────
ADMIN_BOOTSTRAP_PASSWORD=CHANGE_ME_strong_admin_password

# ─── Secrets applicatifs ───────────────────────────────────────────────────
# Génération :
#   openssl rand -base64 48      # JWT_SECRET
#   openssl rand -hex 32         # AES_KEY (32 chars hex = 16 octets binaires)
JWT_SECRET=CHANGE_ME_jwt_secret_min32_chars
AES_KEY=CHANGE_ME_aes_key_16_24_or_32_chars

# ─── IA / RAG ──────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=
GEMINI_API_KEY=
# Clé partagée entre abrpoint.server et le sidecar rag-svc (auth mutuelle).
RAG_SIDECAR_KEY=CHANGE_ME_random_shared_token

# ─── Paiements Stripe ──────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ─── SMTP (OVH par défaut) ─────────────────────────────────────────────────
SMTP_HOST=ssl0.ovh.net
SMTP_PORT=587
SMTP_USERNAME=mohamed@concorde-work-force.com
SMTP_PASSWORD=
SMTP_FROM_NAME=Concorde Work Force
SMTP_FROM_EMAIL=mohamed@concorde-work-force.com

# ─── APK Android (optionnel) ───────────────────────────────────────────────
APK_URL=
APK_VERSION=1.0.0
APK_SIZE_MB=
APK_PUBLISHED_AT=2026-05-15
