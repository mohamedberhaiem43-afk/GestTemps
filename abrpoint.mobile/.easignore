# android/ et ios/ sont désormais ignorés par .gitignore et régénérés par
# `expo prebuild --clean` (cf. eas.json prebuildCommand). On garde tout de même
# ces lignes en sécurité au cas où un dev local ferait `git add -f android/`.
android
ios

# Tarballs et caches qu'on ne veut JAMAIS dans l'archive EAS
node_modules
.expo
.expo-shared
metro-cache
*.log
*.apk
*.aab
*.ipa
