<?xml version="1.0" encoding="utf-8"?>
<!--
  Android Network Security Config — Certificate Pinning.

  Workflow de mise à jour des pins avant build de production :
    1. Lancer `scripts/generate-le-pins.sh` (télécharge les CAs Let's Encrypt
       depuis letsencrypt.org/certs et calcule les SPKI SHA-256 Base64).
    2. Coller les blocs <pin /> dans <pin-set> ci-dessous en respectant la
       redondance : minimum 4 pins (2 roots ISRG + 2 intermédiaires).
    3. Vérifier en double via `scripts/get-cert-pins.sh concorde-work-force.com`
       et comparer les SPKI affichés positions 2+ avec ce fichier.
    4. Lancer `scripts/check-pins-filled.sh` (intégré dans le hook EAS prebuild).
    5. Rebuild l'APK via EAS.

  Tant que <pin-set> est `placeholder-...`, le pinning est INACTIF — le check
  `check-pins-filled.sh` empêche un build prod sans pins valides remplis.

  Stratégie de rotation :
    - ISRG Root X1 + X2 : valides jusqu'en 2035-09, à ne PAS retirer.
    - Intermédiaires R10/R11/E5/E6 : LE les renouvelle tous les 5 ans.
      Rappel calendrier ops à mettre dans le runbook.
    - Le leaf (le certif spécifique au domaine) n'est JAMAIS pinné : LE le
      renouvelle tous les 90 jours via certbot, le pinning casserait l'app.
-->
<network-security-config>
    <!-- Domain principal SaaS -->
    <domain-config cleartextTrafficPermitted="false">
        <domain includeSubdomains="true">concorde-work-force.com</domain>
        <pin-set expiration="2035-09-15">
            <!-- ISRG Root X1 (RSA) — racine primaire LE, valide jusqu'en 2035 -->
            <pin digest="SHA-256">placeholder-isrg-root-x1-run-generate-le-pins-sh</pin>
            <!-- ISRG Root X2 (ECDSA) — racine backup LE, valide jusqu'en 2035 -->
            <pin digest="SHA-256">placeholder-isrg-root-x2-run-generate-le-pins-sh</pin>
            <!-- Let's Encrypt R10 — intermédiaire RSA actuel, rotation 5 ans -->
            <pin digest="SHA-256">placeholder-le-r10-run-generate-le-pins-sh</pin>
            <!-- Let's Encrypt R11 — backup RSA -->
            <pin digest="SHA-256">placeholder-le-r11-run-generate-le-pins-sh</pin>
            <!-- Let's Encrypt E5 — intermédiaire ECDSA actuel -->
            <pin digest="SHA-256">placeholder-le-e5-run-generate-le-pins-sh</pin>
            <!-- Let's Encrypt E6 — backup ECDSA -->
            <pin digest="SHA-256">placeholder-le-e6-run-generate-le-pins-sh</pin>
        </pin-set>
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </domain-config>

    <!-- Default : HTTPS strict pour le reste, pas de cleartext autorisé en prod -->
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>

    <!-- Dev : autorise cleartext sur localhost et IPs LAN courantes pour Expo Go.
         Désactivé en build EAS production via flag (cf. app.json). -->
    <debug-overrides>
        <trust-anchors>
            <certificates src="system" />
            <certificates src="user" />
        </trust-anchors>
    </debug-overrides>
</network-security-config>
