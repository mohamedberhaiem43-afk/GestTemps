{
  "expo": {
    "name": "Concorde Workforce",
    "slug": "concorde-workforce",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "icon": "./assets/Concorde.png",
    "splash": {
      "image": "./assets/Concorde.png",
      "resizeMode": "contain",
      "backgroundColor": "#0040a1"
    },
    "android": {
      "package": "com.concorde.workforce",
      "usesCleartextTraffic": true,
      "adaptiveIcon": {
        "foregroundImage": "./assets/Concorde.png",
        "backgroundColor": "#0040a1"
      },
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.VIBRATE",
        "android.permission.WAKE_LOCK"
      ]
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.concorde.workforce"
    },

    "plugins": [
      "expo-camera",
      "expo-image-picker",
      [
        "expo-notifications",
        {
          "icon": "./assets/Concorde.png",
          "color": "#0040a1",
          "sounds": []
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "kotlinVersion": "2.1.0",
            "usesCleartextTraffic": true
          }
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "5a33d832-4ea8-45a8-8d03-69639df6e080"
      }
    }
  }
}
