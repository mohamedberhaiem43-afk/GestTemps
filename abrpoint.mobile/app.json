{
  "expo": {
    "name": "Concorde Workly",
    "slug": "concorde-workly",
    "version": "1.0.0",
    "orientation": "default",
    "userInterfaceStyle": "light",
    "icon": "./assets/logo_concorde_workly_dark.png",
    "splash": {
      "image": "./assets/concorde-workly-logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#43466b"
    },
    "android": {
      "package": "com.concorde.workly",
      "googleServicesFile": "./google-services.json",
      "usesCleartextTraffic": false,
